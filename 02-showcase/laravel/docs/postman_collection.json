{
  "info": {
    "name": "GATES — Discount Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "1a2b3c4d-5e6f-7890-abcd-ef1234567890",
    "description": "Reference collection for the Laravel discount endpoint. Point {{baseUrl}} at your local server."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" }
  ],
  "item": [
    {
      "name": "Fixed discount — happy path",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/discount", "host": ["{{baseUrl}}"], "path": ["api", "v1", "discount"] },
        "body": { "mode": "raw", "raw": "{\n  \"price\": 200,\n  \"strategy\": \"fixed\",\n  \"value\": 50\n}" }
      }
    },
    {
      "name": "Percentage discount — happy path",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/discount", "host": ["{{baseUrl}}"], "path": ["api", "v1", "discount"] },
        "body": { "mode": "raw", "raw": "{\n  \"price\": 100,\n  \"strategy\": \"percentage\",\n  \"value\": 25\n}" }
      }
    },
    {
      "name": "Loyalty discount",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/discount", "host": ["{{baseUrl}}"], "path": ["api", "v1", "discount"] },
        "body": { "mode": "raw", "raw": "{\n  \"price\": 100,\n  \"strategy\": \"loyalty\"\n}" }
      }
    },
    {
      "name": "Bad request — percentage > 100",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/discount", "host": ["{{baseUrl}}"], "path": ["api", "v1", "discount"] },
        "body": { "mode": "raw", "raw": "{\n  \"price\": 100,\n  \"strategy\": \"percentage\",\n  \"value\": 150\n}" }
      }
    },
    {
      "name": "Bad request — fixed amount > price",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/discount", "host": ["{{baseUrl}}"], "path": ["api", "v1", "discount"] },
        "body": { "mode": "raw", "raw": "{\n  \"price\": 100,\n  \"strategy\": \"fixed\",\n  \"value\": 150\n}" }
      }
    }
  ]
}
